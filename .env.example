# Copy this file to .env and set the real values
# Twenty CRM
TWENTY_API_KEY=your_twenty_api_key_here
TWENTY_BASE_URL=https://api.twenty.com
TWENTY_PERSON_OBJECT_NAME=people
TWENTY_PET_OBJECT_NAME=pets
TWENTY_PET_NAME_FIELD=name
TWENTY_PET_BIRTHDAY_FIELD=birthday
TWENTY_PET_SIZE_FIELD=size
TWENTY_PET_HEALTH_FIELD=healthCondition
TWENTY_PET_REASON_FIELD=reason
TWENTY_PET_FIRST_TIME_FIELD=firstTimeUsing
TWENTY_PET_AGE_FIELD=age
TWENTY_PET_OWNER_RELATION_FIELD=owner
